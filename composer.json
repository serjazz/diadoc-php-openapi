{
    "name": "serjazz/diadoc-php-openapi",
    "description": "Diadoc API client for PHP with OIDC authorization",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/serjazz/diadoc-php-openapi",
    "authors": [
        {
            "name": "Korolev Denis",
            "email": "d.korolev@magdv.com"
        },
        {
            "name": "Sidorov Sergey",
            "email": "serjazz7@gmail.com"
        }
    ],
    "support": {
        "source": "https://github.com/serjazz/diadoc-php-openapi",
        "issues": "https://github.com/serjazz/diadoc-php-openapi/issues"
    },
    "require": {
        "php": ">=7.1.3",
        "google/protobuf": "4.31.1",
        "ext-curl": "*",
        "ext-json": "*",
        "symfony/process": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "MagDv\\Diadoc\\": "src/",
            "GPBMetadata\\": "phpProto/GPBMetadata/",
            "Diadoc\\Proto\\": "phpProto/Diadoc/Proto",
            "Test\\": "tests/"
        }
    },
    "scripts": {
        "generate-proto": "php generate.php",
        "test:compat": "php tests/smoke/run.php"
    },
    "config": {
        "platform": {
            "php": "7.1.33"
        },
        "sort-packages": true,
        "process-timeout": 600
    }
}
