# OAuth приложения (Кабинет интегратора Контур)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Необязательно, по умолчанию https://identity.kontur.ru
# OAUTH_IDENTITY_URL=https://identity.kontur.ru

# Базовый URL API Диадока (боевой или staging)
DIADOC_URL=https://diadoc-api-staging.kontur.ru/

# Redirect для локального теста (docker compose --profile oauth up oauth-test).
# Должен совпадать с URI в Кабинете интегратора и с портом в docker-compose (8765).
# OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback

# Ручная подстановка токенов для тестов / CI (альтернатива файловому кешу в var/)
# DIADOC_ACCESS_TOKEN=
# DIADOC_REFRESH_TOKEN=
# DIADOC_ACCESS_EXPIRES_AT=

ORG_ID=e86a764e-a447-34444-a2b1-11111111111
FROM_BOX_ID=a187f15333333333333333
TO_BOX_ID=aea535b423423424324234234
